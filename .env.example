# Copy this file to `.env` and fill in your own key.
# `.env` is gitignored — it will never be committed.
#
# Alternative: run `simtool config set-key` to store the key encrypted in
# your OS credential store (macOS Keychain / Windows Credential Locker /
# Linux Secret Service) — no file on disk.

ANTHROPIC_API_KEY=sk-ant-...
